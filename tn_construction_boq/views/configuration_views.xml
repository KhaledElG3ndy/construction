    <record id="view_tn_construction_rate_analysis_template_list" model="ir.ui.view">
        <field name="name">tn.construction.rate.analysis.template.list</field>
        <field name="model">tn.construction.rate.analysis.template</field>
        <field name="arch" type="xml">
            <list string="Rate Analysis Templates">
                <field name="name" string="Title"/>
                <field name="work_type_id"/>
                <field name="work_sub_type_id"/>
                <field name="unit_id" string="Unit"/>
                <field name="total_amount"/>
            </list>
        </field>
    </record>

    <record id="view_tn_construction_rate_analysis_template_form" model="ir.ui.view">
        <field name="name">tn.construction.rate.analysis.template.form</field>
        <field name="model">tn.construction.rate.analysis.template</field>
        <field name="arch" type="xml">
            <form string="Rate Analysis Template" class="tn_construction_project_form">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Foundation Standard Rate"/></h1>
                    </div>
                    <group>
                        <group string="Work Type">
                            <field name="work_type_id"/>
                            <field name="work_sub_type_id"/>
                        </group>
                        <group string="Other Detail">
                            <field name="company_id"/>
                            <field name="unit_id"/>
                        </group>
                    </group>
                    <group string="Availability">
                        <div class="tn_rate_availability_row" colspan="2">
                            <span class="tn_rate_availability_item"><field name="material_available" nolabel="1"/><label for="material_available"/></span>
                            <span class="tn_rate_availability_item"><field name="equipment_available" nolabel="1"/><label for="equipment_available"/></span>
                            <span class="tn_rate_availability_item"><field name="labour_available" nolabel="1"/><label for="labour_available"/></span>
                            <span class="tn_rate_availability_item"><field name="overhead_available" nolabel="1"/><label for="overhead_available"/></span>
                        </div>
                    </group>
                    <notebook>
                        <page name="material" string="Material" invisible="not material_available">
                            <field name="material_line_ids" context="{'default_line_type': 'material'}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="line_type" column_invisible="1"/>
                                    <field name="product_id" string="Material"/>
                                    <field name="internal_reference"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                    <field name="sale_price"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="untaxed_amount"/>
                                    <field name="tax_amount"/>
                                    <field name="total_amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page name="equipment" string="Equipment" invisible="not equipment_available">
                            <field name="equipment_line_ids" context="{'default_line_type': 'equipment'}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="line_type" column_invisible="1"/>
                                    <field name="product_id" string="Equipment"/>
                                    <field name="internal_reference"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                    <field name="sale_price"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="untaxed_amount"/>
                                    <field name="tax_amount"/>
                                    <field name="total_amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page name="labour" string="Labour" invisible="not labour_available">
                            <field name="labour_line_ids" context="{'default_line_type': 'labour'}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="line_type" column_invisible="1"/>
                                    <field name="product_id" string="Labour"/>
                                    <field name="internal_reference"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                    <field name="sale_price"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="untaxed_amount"/>
                                    <field name="tax_amount"/>
                                    <field name="total_amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page name="overhead" string="Overhead" invisible="not overhead_available">
                            <field name="overhead_line_ids" context="{'default_line_type': 'overhead'}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="line_type" column_invisible="1"/>
                                    <field name="product_id" string="Overhead"/>
                                    <field name="internal_reference"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                    <field name="sale_price"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="untaxed_amount"/>
                                    <field name="tax_amount"/>
                                    <field name="total_amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <group class="oe_subtotal_footer">
                        <field name="untaxed_amount"/>
                        <field name="tax_amount"/>
                        <field name="total_amount"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tn_construction_rate_analysis_template" model="ir.actions.act_window">
        <field name="name">Rate Analysis Templates</field>
        <field name="res_model">tn.construction.rate.analysis.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
