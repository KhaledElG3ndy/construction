    <record id="view_tn_construction_work_sub_type_form" model="ir.ui.view">
        <field name="name">tn.construction.work.sub.type.form</field>
        <field name="model">tn.construction.work.sub.type</field>
        <field name="arch" type="xml">
            <form string="Work Sub Type">
                <sheet>
                    <group>
