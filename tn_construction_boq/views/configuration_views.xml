        <field name="name">tn.construction.employee.tag.list</field>
        <field name="model">tn.construction.employee.tag</field>
        <field name="arch" type="xml">
            <list string="Employee Tags">
                <field name="name" string="Title"/>
                <field name="color"/>
                <field name="active"/>
            </list>
        </field>
