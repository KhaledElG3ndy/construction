                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tn_construction_work_sub_type" model="ir.actions.act_window">
        <field name="name">Work Sub Types</field>
        <field name="res_model">tn.construction.work.sub.type</field>
        <field name="view_mode">list,form</field>
