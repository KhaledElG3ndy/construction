<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_inherit_tn_construction_flags" model="ir.ui.view">
        <field name="name">product.template.form.inherit.tn.construction.flags</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='purchase_ok']" position="after">
                <field name="is_construction_material"/>
                <field name="is_construction_equipment"/>
                <field name="is_construction_labour"/>
                <field name="is_construction_overhead"/>
                <field name="is_construction_expense"/>
            </xpath>
        </field>
    </record>

    <record id="action_tn_construction_material_products" model="ir.actions.act_window">
        <field name="name">Materials</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_construction_material', '=', True)]</field>
        <field name="context">{'default_is_construction_material': True, 'default_purchase_ok': True, 'default_sale_ok': True}</field>
    </record>

    <record id="action_tn_construction_equipment_products" model="ir.actions.act_window">
        <field name="name">Equipments</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_construction_equipment', '=', True)]</field>
        <field name="context">{'default_is_construction_equipment': True, 'default_purchase_ok': True, 'default_sale_ok': True}</field>
    </record>

    <record id="action_tn_construction_labour_products" model="ir.actions.act_window">
        <field name="name">Labours</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_construction_labour', '=', True)]</field>
        <field name="context">{'default_is_construction_labour': True, 'default_purchase_ok': True, 'default_sale_ok': True, 'default_type': 'service'}</field>
    </record>

    <record id="action_tn_construction_overhead_products" model="ir.actions.act_window">
        <field name="name">Overheads</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_construction_overhead', '=', True)]</field>
        <field name="context">{'default_is_construction_overhead': True, 'default_purchase_ok': True, 'default_sale_ok': True}</field>
    </record>

    <record id="action_tn_construction_expense_products" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_construction_expense', '=', True)]</field>
        <field name="context">{'default_is_construction_expense': True, 'default_purchase_ok': True, 'default_sale_ok': False, 'default_type': 'service'}</field>
    </record>

    <record id="view_tn_construction_work_type_list" model="ir.ui.view">
        <field name="name">tn.construction.work.type.list</field>
        <field name="model">tn.construction.work.type</field>
        <field name="arch" type="xml">
            <list string="Work Types">
                <field name="name" string="Title"/>
                <field name="sub_type_ids" string="Work Sub Type" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="view_tn_construction_work_type_form" model="ir.ui.view">
        <field name="name">tn.construction.work.type.form</field>
        <field name="model">tn.construction.work.type</field>
        <field name="arch" type="xml">
            <form string="Work Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sub_type_ids" widget="many2many_tags"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tn_construction_work_type" model="ir.actions.act_window">
        <field name="name">Work Types</field>
        <field name="res_model">tn.construction.work.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_tn_construction_work_sub_type_list" model="ir.ui.view">
        <field name="name">tn.construction.work.sub.type.list</field>
