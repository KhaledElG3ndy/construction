<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_tn_construction_internal_transfer" model="ir.sequence">
        <field name="name">Construction Internal Transfer</field>
        <field name="code">tn.construction.internal.transfer</field>
        <field name="prefix">IT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_tn_construction_scrap_order" model="ir.sequence">
        <field name="name">Construction Scrap Order</field>
        <field name="code">tn.construction.scrap.order</field>
        <field name="prefix">CS/SCRAP/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="view_tn_construction_internal_transfer_search" model="ir.ui.view">
        <field name="name">tn.construction.internal.transfer.search</field>
        <field name="model">tn.construction.internal.transfer</field>
        <field name="arch" type="xml">
            <search string="Internal Transfer">
                <field name="name"/>
                <field name="title"/>
                <field name="project_id"/>
                <field name="sub_project_id"/>
                <field name="work_order_id"/>
                <field name="material_request_id"/>
                <field name="project_warehouse_id"/>
                <field name="state"/>
                <filter string="In Progress" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Company" name="group_company" context="{'group_by': 'company_id'}"/>
                <filter string="Project Warehouse" name="group_project_warehouse" context="{'group_by': 'project_warehouse_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_tn_construction_internal_transfer_list" model="ir.ui.view">
        <field name="name">tn.construction.internal.transfer.list</field>
        <field name="model">tn.construction.internal.transfer</field>
        <field name="arch" type="xml">
            <list string="Internal Transfer" default_order="date desc, id desc">
                <field name="name" string="Sequence"/>
                <field name="date"/>
                <field name="created_by_id" widget="many2one_avatar_user"/>
                <field name="company_id"/>
                <field name="project_warehouse_id"/>
                <field name="state" string="Stage" widget="badge"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_tn_construction_internal_transfer_form" model="ir.ui.view">
        <field name="name">tn.construction.internal.transfer.form</field>
        <field name="model">tn.construction.internal.transfer</field>
        <field name="arch" type="xml">
            <form string="Internal Transfer" class="tn_construction_project_form">
                <header>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-danger" invisible="state in ['cancelled', 'done']"/>
                    <button name="action_set_in_progress" type="object" string="In Progress" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" type="object" string="Done" class="btn-primary" invisible="state != 'in_progress'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <h2><field name="title" placeholder="Transfer description..."/></h2>
                    </div>
                    <group>
                        <group string="Project Details">
                            <field name="project_id" string="Site"/>
                            <field name="sub_project_id"/>
                            <field name="company_id"/>
                            <field name="project_warehouse_id"/>
                        </group>
                        <group string="Other Details">
                            <field name="date"/>
                            <field name="created_by_id" widget="many2one_avatar_user"/>
                        </group>
                    </group>
                    <group string="Work Type &amp; Project Phase(WBS)">
                        <group>
                            <field name="work_type"/>
                            <field name="work_order_id"/>
                        </group>
                        <group>
                            <field name="phase_id" string="Phase(WBS)"/>
                            <field name="material_request_id" string="Material Req"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="internal_transfer" string="Internal Transfer">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="work_sub_type" string="Work Sub Type"/>
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="forecast_qty"/>
                                    <field name="uom_id"/>
                                    <field name="pickup_warehouse_id" string="Pickup Warehouse"/>
                                    <field name="delivery_warehouse_id" string="Delivery Warehouse"/>
                                    <field name="delivery_order" string="DO"/>
                                </list>
                            </field>
                            <div class="d-flex justify-content-end pt-3">
                                <button name="action_create_internal_transfer" type="object" string="Create Internal Transfer" class="btn-primary"/>
                            </div>
                        </page>
                        <page name="additional_info" string="Additional Info">
                            <group>
                                <group string="Vehicle Details">
                                    <field name="vehicle_no"/>
                                    <field name="vehicle_model"/>
                                </group>
                                <group>
                                    <field name="vehicle_name"/>
                                </group>
                            </group>
                            <group string="Driver Details">
                                <field name="driver_name"/>
                                <field name="driver_phone"/>
                            </group>
                            <field name="stock_picking_id" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tn_construction_internal_transfer" model="ir.actions.act_window">
        <field name="name">Internal Transfer</field>
        <field name="res_model">tn.construction.internal.transfer</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_in_progress': 1}</field>
        <field name="search_view_id" ref="view_tn_construction_internal_transfer_search"/>
    </record>

    <record id="view_tn_construction_scrap_order_search" model="ir.ui.view">
        <field name="name">tn.construction.scrap.order.search</field>
        <field name="model">tn.construction.scrap.order</field>
        <field name="arch" type="xml">
            <search string="Scrap Order">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="work_order_id"/>
                <field name="date"/>
                <filter string="Work Order" name="group_work_order" context="{'group_by': 'work_order_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_tn_construction_scrap_order_list" model="ir.ui.view">
        <field name="name">tn.construction.scrap.order.list</field>
        <field name="model">tn.construction.scrap.order</field>
        <field name="arch" type="xml">
            <list string="Scrap Order" default_order="date desc, id desc">
                <field name="name" string="Sequence"/>
                <field name="work_order_id"/>
                <field name="date"/>
                <field name="total_amount" string="Total"/>
            </list>
        </field>
    </record>

    <record id="view_tn_construction_scrap_order_form" model="ir.ui.view">
        <field name="name">tn.construction.scrap.order.form</field>
        <field name="model">tn.construction.scrap.order</field>
        <field name="arch" type="xml">
            <form string="Scrap Order" class="tn_construction_project_form">
                <header>
                    <button name="action_create_invoice" type="object" string="Create Invoice" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" string="Vendor"/>
                            <field name="work_order_id"/>
                            <field name="note"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="company_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="invoice_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="scrap_order" string="Scrap Order">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="scrap_type" string="Scrap of"/>
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                    <field name="company_id"/>
                                    <field name="currency_id"/>
                                    <field name="value"/>
                                    <field name="total_value"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_amount" string="Total"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tn_construction_scrap_order" model="ir.actions.act_window">
        <field name="name">Scrap Order</field>
        <field name="res_model">tn.construction.scrap.order</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tn_construction_scrap_order_search"/>
    </record>
</odoo>
