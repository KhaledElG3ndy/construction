        <field name="views" eval="[(ref('view_tn_construction_quality_check_overhead_list'), 'list'), (ref('view_tn_construction_quality_check_form'), 'form')]"/>
    </record>

    <record id="action_tn_construction_quality_check_material" model="ir.actions.act_window">
        <field name="name">Materials Quality Check</field>
        <field name="res_model">tn.construction.quality.check</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('check_kind', '=', 'material')]</field>
        <field name="context">{'default_check_kind': 'material', 'search_default_department_approval': 1}</field>
        <field name="search_view_id" ref="view_tn_construction_quality_check_search"/>
        <field name="views" eval="[(ref('view_tn_construction_quality_check_material_list'), 'list'), (ref('view_tn_construction_quality_check_form'), 'form')]"/>
    </record>
</odoo>
