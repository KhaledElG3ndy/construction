<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tn_construction_budget_list" model="ir.ui.view">
        <field name="name">tn.construction.budget.list</field>
        <field name="model">tn.construction.budget</field>
        <field name="arch" type="xml">
            <list string="Sub Project Budgets"
                  decoration-muted="state == 'draft'"
                  decoration-info="state in ('waiting_approval', 'in_progress')"
                  decoration-success="state in ('approved', 'completed')">
                <field name="name"/>
                <field name="project_id"/>
                <field name="sub_project_id"/>
                <field name="company_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="responsible_id" widget="many2one_avatar_user"/>
                <field name="total_budget_amount" sum="Total Budget"/>
                <field name="budget_utilization" sum="Budget Utilization"/>
                <field name="progress" widget="progressbar"/>
                <field name="state" widget="badge"
                       decoration-muted="state == 'draft'"
                       decoration-warning="state == 'waiting_approval'"
                       decoration-success="state == 'approved'"
                       decoration-info="state == 'in_progress'"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_tn_construction_budget_form" model="ir.ui.view">
        <field name="name">tn.construction.budget.form</field>
        <field name="model">tn.construction.budget</field>
        <field name="arch" type="xml">
            <form string="Sub Project Budget" class="tn_construction_project_form">
                <header>
                    <button name="action_submit_for_approval"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'waiting_approval'"/>
                    <button name="action_start"
                            string="Start"
                            type="object"
                            invisible="state != 'approved'"/>
                    <button name="action_complete"
                            string="Complete"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ('approved', 'in_progress')"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,waiting_approval,approved,in_progress"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_budget_lines"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-tasks">
                            <field name="line_count" widget="statinfo" string="Budget Lines"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Tower A Approved Budget"/></h1>
                    </div>
                    <group>
                        <group string="Project Details">
                            <field name="project_id"/>
                            <field name="sub_project_id"/>
                            <field name="company_id"/>
                        </group>
                        <group string="Other Details">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="responsible_id" widget="many2one_avatar_user"/>
                            <field name="progress" widget="progressbar"/>
                        </group>
                    </group>
                    <group string="Budget Details">
                        <group>
                            <field name="total_budget_amount" widget="monetary"/>
                            <field name="budget_utilization" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Budget Line Confirmation">
                        <field name="confirmation_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="action_type" widget="badge"
                                       decoration-success="action_type == 'insert'"
                                       decoration-info="action_type == 'update'"
                                       decoration-danger="action_type == 'delete'"/>
                                <field name="date"/>
                                <field name="requested_by_id" widget="many2one_avatar_user"/>
                                <field name="status" widget="badge"
                                       decoration-info="status == 'requested'"
                                       decoration-success="status == 'approved'"
                                       decoration-danger="status == 'rejected'"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tn_construction_budget_search" model="ir.ui.view">
        <field name="name">tn.construction.budget.search</field>
        <field name="model">tn.construction.budget</field>
        <field name="arch" type="xml">
            <search string="Sub Project Budgets">
                <field name="name"/>
                <field name="project_id"/>
                <field name="sub_project_id"/>
                <field name="responsible_id"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="waiting_approval" string="Waiting Approval" domain="[('state', '=', 'waiting_approval')]"/>
                <filter name="approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <filter name="in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_project" string="Project" context="{'group_by': 'project_id'}"/>
                    <filter name="group_sub_project" string="Sub Project" context="{'group_by': 'sub_project_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_tn_construction_budget_line_list" model="ir.ui.view">
        <field name="name">tn.construction.budget.line.list</field>
        <field name="model">tn.construction.budget.line</field>
        <field name="arch" type="xml">
            <list string="Budget Lines"
                  decoration-success="total_budget_amount &gt;= 0">
                <field name="work_type"/>
                <field name="work_sub_type"/>
                <field name="boq_qty" sum="BOQ Qty"/>
                <field name="additional_qty" sum="Add. Qty"/>
                <field name="rate_analysis"/>
                <field name="price_qty"/>
                <field name="untaxed_amount" sum="Untaxed Amount"/>
                <field name="tax_amount" sum="Tax Amount"/>
                <field name="total_budget_amount" sum="Total Budget"/>
                <field name="material_spent" sum="Material Spent"/>
                <field name="equipment_spent" sum="Equipment Spent"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_tn_construction_budget_line_form" model="ir.ui.view">
        <field name="name">tn.construction.budget.line.form</field>
        <field name="model">tn.construction.budget.line</field>
        <field name="arch" type="xml">
            <form string="Budget Line">
                <sheet>
                    <group>
                        <group>
                            <field name="budget_id"/>
                            <field name="project_id"/>
                            <field name="sub_project_id"/>
                            <field name="work_type"/>
                            <field name="work_sub_type"/>
                            <field name="rate_analysis"/>
                        </group>
                        <group>
                            <field name="boq_qty"/>
                            <field name="additional_qty"/>
                            <field name="price_qty"/>
                            <field name="untaxed_amount"/>
                            <field name="tax_amount"/>
                            <field name="total_budget_amount"/>
                            <field name="material_spent"/>
                            <field name="equipment_spent"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tn_construction_budget_line_search" model="ir.ui.view">
        <field name="name">tn.construction.budget.line.search</field>
        <field name="model">tn.construction.budget.line</field>
        <field name="arch" type="xml">
            <search string="Budget Lines">
                <field name="budget_id"/>
                <field name="project_id"/>
                <field name="sub_project_id"/>
                <field name="work_type"/>
                <field name="work_sub_type"/>
                <group expand="0" string="Group By">
                    <filter name="group_work_type" string="Work Type" context="{'group_by': 'work_type'}"/>
                    <filter name="group_work_sub_type" string="Work Sub Type" context="{'group_by': 'work_sub_type'}"/>
                    <filter name="group_budget" string="Budget" context="{'group_by': 'budget_id'}"/>
                </group>
                <searchpanel>
                    <field name="work_type" string="Work Type"/>
                    <field name="work_sub_type" string="Work Sub Type"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="view_tn_construction_rate_analysis_list" model="ir.ui.view">
        <field name="name">tn.construction.rate.analysis.list</field>
        <field name="model">tn.construction.rate.analysis</field>
        <field name="arch" type="xml">
            <list string="Rate Analysis">
                <field name="name" string="Title"/>
                <field name="project_id"/>
                <field name="sub_project_id"/>
                <field name="date"/>
                <field name="work_type"/>
                <field name="work_sub_type"/>
                <field name="total_amount" sum="Total Amount"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_tn_construction_rate_analysis_form" model="ir.ui.view">
        <field name="name">tn.construction.rate.analysis.form</field>
        <field name="model">tn.construction.rate.analysis</field>
        <field name="arch" type="xml">
            <form string="Rate Analysis" class="tn_construction_project_form">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Foundation Footings Rate Analysis"/></h1>
                    </div>
                    <group>
                        <group string="Project Details">
                            <field name="project_id"/>
                            <field name="sub_project_id"/>
                            <field name="company_id"/>
                        </group>
                        <group string="Work Type">
                            <field name="work_type"/>
                            <field name="work_sub_type"/>
                            <field name="template"/>
                        </group>
                    </group>
                    <group string="BOQ Type">
                        <field name="boq_type" widget="radio"/>
                        <div class="text-muted" colspan="2">
                            <p><strong>Qty per Unit:</strong> quantity required for each unit of the item.</p>
                            <p><strong>Total Required Qty:</strong> total quantity needed for the complete batch or target.</p>
                        </div>
                    </group>
                    <group string="Other Details">
                        <group>
                            <field name="unit_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                        </group>
                    </group>
                    <group string="Availability">
                        <div class="tn_rate_availability_row" colspan="2">
                            <span class="tn_rate_availability_item">
                                <field name="material_available" nolabel="1"/>
                                <label for="material_available"/>
                            </span>
                            <span class="tn_rate_availability_item">
                                <field name="equipment_available" nolabel="1"/>
                                <label for="equipment_available"/>
                            </span>
                            <span class="tn_rate_availability_item">
                                <field name="labour_available" nolabel="1"/>
                                <label for="labour_available"/>
                            </span>
                            <span class="tn_rate_availability_item">
                                <field name="overhead_available" nolabel="1"/>
                                <label for="overhead_available"/>
                            </span>
                        </div>
                    </group>
                    <notebook>
                        <page name="material" string="Material" invisible="not material_available">
                            <field name="material_line_ids" context="{'default_line_type': 'material'}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="line_type" column_invisible="1"/>
                                    <field name="product_id" string="Material"/>
                                    <field name="internal_reference"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                    <field name="cost_price" sum="Cost Price"/>
                                    <field name="sale_price" sum="Sale Price"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="untaxed_amount" sum="Untaxed Amount"/>
                                    <field name="tax_amount" sum="Tax Amount"/>
                                    <field name="total_amount" sum="Total Amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page name="equipment" string="Equipment" invisible="not equipment_available">
                            <field name="equipment_line_ids" context="{'default_line_type': 'equipment'}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="line_type" column_invisible="1"/>
                                    <field name="product_id" string="Equipment"/>
                                    <field name="internal_reference"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                    <field name="cost_price" sum="Cost Price"/>
                                    <field name="sale_price" sum="Sale Price"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="untaxed_amount" sum="Untaxed Amount"/>
                                    <field name="tax_amount" sum="Tax Amount"/>
                                    <field name="total_amount" sum="Total Amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page name="labour" string="Labour" invisible="not labour_available">
                            <field name="labour_line_ids" context="{'default_line_type': 'labour'}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="line_type" column_invisible="1"/>
                                    <field name="product_id" string="Labour"/>
                                    <field name="internal_reference"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                    <field name="cost_price" sum="Cost Price"/>
                                    <field name="sale_price" sum="Sale Price"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="untaxed_amount" sum="Untaxed Amount"/>
                                    <field name="tax_amount" sum="Tax Amount"/>
                                    <field name="total_amount" sum="Total Amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page name="overhead" string="Overhead" invisible="not overhead_available">
                            <field name="overhead_line_ids" context="{'default_line_type': 'overhead'}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="line_type" column_invisible="1"/>
                                    <field name="product_id" string="Overhead"/>
                                    <field name="internal_reference"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                    <field name="cost_price" sum="Cost Price"/>
                                    <field name="sale_price" sum="Sale Price"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="untaxed_amount" sum="Untaxed Amount"/>
                                    <field name="tax_amount" sum="Tax Amount"/>
                                    <field name="total_amount" sum="Total Amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page name="employee_hours" string="Employee Hours">
                            <field name="employee_hour_ids">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="employee_id" widget="many2one_avatar_user"/>
                                    <field name="phase_id"/>
                                    <field name="work_order_id"/>
                                    <field name="hour_worked" sum="Hour Worked"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <group>
                        <group string="Cost Price Total">
                            <field name="cost_untaxed_amount" widget="monetary"/>
                            <field name="cost_tax_amount" widget="monetary"/>
                            <field name="cost_total_amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Sale Price Total">
                            <field name="sale_untaxed_amount" widget="monetary"/>
                            <field name="sale_tax_amount" widget="monetary"/>
                            <field name="sale_total_amount" widget="monetary"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tn_construction_rate_analysis_search" model="ir.ui.view">
        <field name="name">tn.construction.rate.analysis.search</field>
        <field name="model">tn.construction.rate.analysis</field>
        <field name="arch" type="xml">
            <search string="Rate Analysis">
                <field name="name"/>
                <field name="project_id"/>
                <field name="sub_project_id"/>
                <field name="work_type"/>
                <field name="work_sub_type"/>
                <filter name="today" string="Today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_project" string="Project" context="{'group_by': 'project_id'}"/>
                    <filter name="group_sub_project" string="Sub Project" context="{'group_by': 'sub_project_id'}"/>
                    <filter name="group_work_type" string="Work Type" context="{'group_by': 'work_type'}"/>
                    <filter name="group_work_sub_type" string="Work Sub Type" context="{'group_by': 'work_sub_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_tn_boq_line_list" model="ir.ui.view">
        <field name="name">tn.boq.line.list</field>
        <field name="model">tn.boq.line</field>
        <field name="arch" type="xml">
            <list string="BOQ Budget Lines"
                  decoration-danger="percent_committed &gt; 100"
                  decoration-warning="percent_committed &gt; 90 and percent_committed &lt;= 100">
                <field name="project_id"/>
                <field name="product_id"/>
                <field name="description" optional="hide"/>
                <field name="uom_id"/>
                <field name="approved_qty" sum="Approved Qty"/>
                <field name="approved_rate"/>
                <field name="approved_value" sum="Approved Value"/>
                <field name="committed_qty" sum="Committed Qty"/>
                <field name="remaining_qty" sum="Remaining Qty"/>
                <field name="percent_committed" widget="percentage" optional="show"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_tn_boq_line_form" model="ir.ui.view">
        <field name="name">tn.boq.line.form</field>
        <field name="model">tn.boq.line</field>
        <field name="arch" type="xml">
            <form string="BOQ Budget Line">
                <sheet>
                    <group>
                        <group string="BOQ Item">
                            <field name="project_id"/>
                            <field name="product_id"/>
                            <field name="description"/>
                            <field name="uom_id"/>
                            <field name="analytic_account_id"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Approved Budget">
                            <field name="approved_qty"/>
                            <field name="approved_rate"/>
                            <field name="approved_value" widget="monetary"/>
                        </group>
                    </group>
                    <group string="Commitment Status">
                        <group>
                            <field name="committed_qty"/>
                            <field name="remaining_qty"/>
                        </group>
                        <group>
                            <field name="percent_committed" widget="percentage"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tn_boq_line_search" model="ir.ui.view">
        <field name="name">tn.boq.line.search</field>
        <field name="model">tn.boq.line</field>
        <field name="arch" type="xml">
            <search string="BOQ Budget Lines">
                <field name="project_id"/>
                <field name="product_id"/>
                <field name="analytic_account_id"/>
                <filter name="over_budget" string="Over Budget"
                        domain="[('remaining_qty', '&lt;', 0)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_project" string="Project"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_product" string="BOQ Item"
                            context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tn_construction_budget" model="ir.actions.act_window">
        <field name="name">Sub Project Budgets</field>
        <field name="res_model">tn.construction.budget</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tn_construction_budget_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a sub project budget.
            </p>
        </field>
    </record>

    <record id="action_tn_construction_budget_line" model="ir.actions.act_window">
        <field name="name">Budget Lines</field>
        <field name="res_model">tn.construction.budget.line</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tn_construction_budget_line_search"/>
    </record>

    <record id="action_tn_construction_rate_analysis" model="ir.actions.act_window">
        <field name="name">Rate Analysis</field>
        <field name="res_model">tn.construction.rate.analysis</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tn_construction_rate_analysis_search"/>
    </record>

    <record id="action_tn_boq_line" model="ir.actions.act_window">
        <field name="name">BOQ Budget Control</field>
        <field name="res_model">tn.boq.line</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define the approved Bill of Quantities per project.
            </p>
            <p>
                Each line caps the quantity that can be committed via purchase
                orders for a product on a project. Exceeding it is blocked until
                a Variation Order override is approved.
            </p>
        </field>
    </record>

    <menuitem id="menu_tn_boq_root"
              name="BOQ Budget Control"
              parent="project.menu_main_pm"
              sequence="25"/>

    <menuitem id="menu_tn_boq_line"
              name="BOQ Control Lines"
              parent="menu_tn_boq_root"
              action="action_tn_boq_line"
              sequence="10"/>

</odoo>
