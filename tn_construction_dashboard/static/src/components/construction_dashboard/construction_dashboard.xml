<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="tn_construction_dashboard.SectionTitle">
        <div class="tn_cd_section_title">
            <h2 t-esc="title"/>
        </div>
    </t>

    <t t-name="tn_construction_dashboard.MetricCard">
        <button type="button" t-att-data-key="metric.key" t-attf-class="tn_cd_card tn_cd_tone_#{metric.tone}" t-on-click="onMetricClick">
            <span class="tn_cd_icon"><i t-attf-class="fa #{metric.icon || 'fa-circle'}"/></span>
            <span class="tn_cd_card_value" t-esc="metric.value || 0"/>
            <span class="tn_cd_card_label" t-esc="metric.label"/>
        </button>
    </t>

    <t t-name="tn_construction_dashboard.StatusRows">
        <div class="tn_cd_status_rows">
            <t t-foreach="items" t-as="status" t-key="status.key">
                <button type="button"
                        t-att-data-model="modelKey"
                        t-att-data-state="status.key"
                        t-att-disabled="status.empty ? true : undefined"
                        t-on-click="onStatusClick">
                    <span>
                        <i t-att-style="'background:' + status.color"/>
                        <t t-esc="status.label"/>
                    </span>
                    <strong t-esc="status.value"/>
                </button>
            </t>
        </div>
    </t>

    <t t-name="tn_construction_dashboard.ConstructionDashboard">
        <div class="tn_cd" t-att-dir="isRTL ? 'rtl' : 'ltr'">
            <t t-if="state.loading">
                <div class="tn_cd_loading">
                    <i class="fa fa-circle-o-notch fa-spin"/>
                </div>
            </t>
            <t t-else="">
                <header class="tn_cd_header">
                    <div>
                        <h1 t-esc="text.dashboard"/>
                        <p t-esc="text.dashboardSubtitle"/>
                    </div>
                    <div class="tn_cd_header_tools">
                        <div class="tn_cd_tool_wrap">
                            <button type="button" class="tn_cd_tool_button" t-on-click="toggleDatePanel">
                                <i class="fa fa-calendar-o"/> <t t-esc="dateRangeLabel"/>
                            </button>
                            <div class="tn_cd_dropdown tn_cd_date_dropdown" t-if="state.datePanelOpen">
                                <div class="tn_cd_preset_grid">
                                    <t t-foreach="datePresets" t-as="preset" t-key="preset.key">
                                        <button type="button"
                                                t-att-data-preset="preset.key"
                                                t-att-class="'tn_cd_filter_pill' + (state.filters.datePreset === preset.key ? ' is-active' : '')"
                                                t-on-click="onDatePresetClick"
                                                t-esc="preset.label"/>
                                    </t>
                                </div>
                                <div class="tn_cd_date_inputs">
                                    <label>
                                        <span t-esc="text.from"/>
                                        <input type="date" t-att-value="state.filters.dateFrom" t-on-change="onDateFromChange"/>
                                    </label>
                                    <label>
                                        <span t-esc="text.to"/>
                                        <input type="date" t-att-value="state.filters.dateTo" t-on-change="onDateToChange"/>
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="tn_cd_tool_wrap">
                            <button type="button" class="tn_cd_tool_button" t-on-click="toggleFilterPanel">
                                <i class="fa fa-sliders"/> <t t-esc="text.filters"/>
                                <strong t-if="activeFilterCount" t-esc="activeFilterCount"/>
                            </button>
                            <div class="tn_cd_dropdown tn_cd_filter_dropdown" t-if="state.filterPanelOpen">
                                <div class="tn_cd_filter_grid">
                                    <label>
                                        <span t-esc="text.project"/>
                                        <select t-on-change="onProjectChange">
                                            <option value="" t-att-selected="!state.filters.projectId ? true : undefined" t-esc="text.allProjects"/>
                                            <t t-foreach="state.filterOptions.projects" t-as="project" t-key="project.id">
                                                <option t-att-value="project.id"
                                                        t-att-selected="state.filters.projectId === project.id ? true : undefined"
                                                        t-esc="project.display_name || project.name"/>
                                            </t>
                                        </select>
                                    </label>
                                    <label>
                                        <span t-esc="text.subProject"/>
                                        <select t-on-change="onSubProjectChange">
                                            <option value="" t-att-selected="!state.filters.subProjectId ? true : undefined" t-esc="text.allSubProjects"/>
                                            <t t-foreach="filteredSubProjects" t-as="subProject" t-key="subProject.id">
                                                <option t-att-value="subProject.id"
                                                        t-att-selected="state.filters.subProjectId === subProject.id ? true : undefined"
                                                        t-esc="subProject.display_name || subProject.name"/>
                                            </t>
                                        </select>
                                    </label>
                                    <label>
                                        <span t-esc="text.stage"/>
                                        <select t-on-change="onStageChange">
                                            <option value="" t-att-selected="!state.filters.stage ? true : undefined" t-esc="text.allStages"/>
                                            <t t-foreach="stageOptions" t-as="stage" t-key="stage.key">
                                                <option t-att-value="stage.key"
                                                        t-att-selected="state.filters.stage === stage.key ? true : undefined"
                                                        t-esc="stage.label"/>
                                            </t>
                                        </select>
                                    </label>
                                </div>
                                <div class="tn_cd_filter_actions">
                                    <button type="button" t-on-click="resetFilters">
                                        <i class="fa fa-undo"/> <t t-esc="text.resetFilters"/>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </header>

                <div class="tn_cd_active_filters" t-if="activeFilterChips.length">
                    <t t-foreach="activeFilterChips" t-as="chip" t-key="chip.key">
                        <button type="button" t-att-data-filter="chip.key" t-on-click="onRemoveFilter">
                            <span t-esc="chip.label"/>
                            <i class="fa fa-times"/>
                        </button>
                    </t>
                    <span t-if="state.refreshing" class="tn_cd_refreshing"><i class="fa fa-circle-o-notch fa-spin"/></span>
                </div>

                <section>
                    <t t-call="tn_construction_dashboard.SectionTitle">
                        <t t-set="title" t-value="text.quickAccess"/>
                    </t>
                    <div class="tn_cd_kpi_strip">
                        <t t-foreach="quickMetrics" t-as="metric" t-key="metric.key">
                            <button type="button" t-att-data-key="metric.key" t-attf-class="tn_cd_kpi tn_cd_tone_#{metric.tone}" t-on-click="onMetricClick">
                                <span class="tn_cd_icon"><i t-attf-class="fa #{metric.icon}"/></span>
                                <span class="tn_cd_kpi_main">
                                    <span class="tn_cd_card_value" t-esc="metric.value || 0"/>
                                    <span class="tn_cd_card_label" t-esc="metric.label"/>
                                </span>
                                <span class="tn_cd_kpi_footer">
                                    <t t-esc="text.viewAll"/> <i class="fa fa-arrow-right"/>
                                </span>
                            </button>
                        </t>
                    </div>
                </section>

                <section>
                    <t t-call="tn_construction_dashboard.SectionTitle">
                        <t t-set="title" t-value="text.portfolio"/>
                    </t>
                    <div class="tn_cd_portfolio_grid">
                        <article class="tn_cd_panel tn_cd_overview_panel">
                            <h3><i class="fa fa-th-large"/> <t t-esc="text.portfolioOverview"/></h3>
                            <div class="tn_cd_overview_rows">
                                <t t-foreach="portfolioMetrics" t-as="metric" t-key="metric.key">
                                    <button type="button" t-att-data-key="metric.key" t-on-click="onMetricClick">
                                        <span><i t-attf-class="fa #{metric.icon}"/> <t t-esc="metric.label"/></span>
                                        <strong t-esc="metric.value || 0"/>
                                    </button>
                                </t>
                            </div>
                            <div class="tn_cd_completion">
                                <div>
                                    <span t-esc="text.completion"/>
                                    <strong t-esc="completionLabel"/>
                                </div>
                                <button type="button" data-key="completion" t-on-click="onMetricClick">
                                    <span t-att-style="'width:' + (state.counts.completion || 0) + '%'"/>
                                </button>
                            </div>
                        </article>

                        <article class="tn_cd_panel">
                            <h3><i class="fa fa-play"/> <t t-esc="text.executionStages"/></h3>
                            <div class="tn_cd_stage_grid">
                                <t t-foreach="stageMetrics" t-as="metric" t-key="metric.key">
                                    <button type="button" t-att-data-key="metric.key" t-attf-class="tn_cd_stage_tile tn_cd_tone_#{metric.tone}" t-on-click="onMetricClick">
                                        <span t-esc="metric.label"/>
                                        <strong t-esc="metric.value || 0"/>
                                    </button>
                                </t>
                            </div>
                        </article>

                        <article class="tn_cd_panel tn_cd_timeline_panel">
                            <h3><i class="fa fa-calendar-o"/> <t t-esc="text.projectTimeline"/></h3>
                            <div class="tn_cd_timeline_body">
                                <div class="tn_cd_ring" t-att-style="'--progress:' + (state.timeline.progress || 0)">
                                    <span><t t-esc="state.timeline.progress || 0"/>%</span>
                                </div>
                                <div>
                                    <strong t-if="state.timeline.days">
                                        <t t-esc="state.timeline.days"/> <t t-esc="text.days"/>
                                    </strong>
                                    <strong t-else="" t-esc="text.noData"/>
                                    <small t-esc="state.timeline.label"/>
                                    <p t-if="!state.timeline.days" t-esc="text.addSubProjects"/>
                                </div>
                            </div>
                            <div class="tn_cd_status_links">
                                <button type="button" data-key="subProjects" t-on-click="onMetricClick">
                                    <span><i/> <t t-esc="text.subProjectStages"/></span>
                                    <strong t-esc="state.counts.subProjects || 0"/>
                                </button>
                                <button type="button" data-key="workOrders" t-on-click="onMetricClick">
                                    <span><i/> <t t-esc="text.workOrderStatus"/></span>
                                    <strong t-esc="state.counts.openWorkOrders || 0"/>
                                </button>
                            </div>
                        </article>
                    </div>
                </section>

                <section>
                    <t t-call="tn_construction_dashboard.SectionTitle">
                        <t t-set="title" t-value="text.operations"/>
                    </t>
                    <div class="tn_cd_operations_grid">
                        <article class="tn_cd_panel tn_cd_operation_panel">
                            <h3><i class="fa fa-archive"/> <t t-esc="text.materials"/></h3>
                            <div class="tn_cd_operation_empty" t-if="!state.counts.materialRequests">
                                <i class="fa fa-chain-broken"/>
                                <span t-esc="text.noMaterialRequests"/>
                            </div>
                            <t t-else="">
                                <t t-set="items" t-value="state.materialStatuses"/>
                                <t t-set="modelKey" t-value="'materialRequests'"/>
                                <t t-call="tn_construction_dashboard.StatusRows"/>
                            </t>
                            <div class="tn_cd_operation_footer">
                                <span t-esc="text.materialRequestStatus"/>
                                <button type="button" data-key="openMaterialRequests" t-on-click="onMetricClick">
                                    <t t-esc="state.counts.openMaterialRequests || 0"/> <t t-esc="text.open"/>
                                </button>
                            </div>
                        </article>

                        <article class="tn_cd_panel tn_cd_operation_panel">
                            <h3><i class="fa fa-bolt"/> <t t-esc="text.transfers"/></h3>
                            <div class="tn_cd_operation_empty" t-if="!state.counts.internalTransfers">
                                <i class="fa fa-arrows-v"/>
                                <span t-esc="text.noTransfers"/>
                            </div>
                            <t t-else="">
                                <t t-set="items" t-value="state.transferStatuses"/>
                                <t t-set="modelKey" t-value="'internalTransfers'"/>
                                <t t-call="tn_construction_dashboard.StatusRows"/>
                            </t>
                            <div class="tn_cd_operation_footer">
                                <span t-esc="text.transferStatus"/>
                                <button type="button" data-key="internalTransfers" t-on-click="onMetricClick">
                                    <t t-esc="state.counts.openInternalTransfers || 0"/> <t t-esc="text.pending"/>
                                </button>
                            </div>
                        </article>
                    </div>
                </section>
            </t>
        </div>
    </t>
</templates>
